{
    "manifest_version": 3,
    "name": "ProdMemo",
    "version": "2.0.0",
    "description": "Syncs submitted alphas and calculates local correlation for WorldQuant Brain.",
    "permissions": [
        "storage",
        "downloads",
        "activeTab"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "host_permissions": [
        "*://*.worldquantbrain.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js",
                "styles.css"
            ],
            "matches": [
                "*://*.worldquantbrain.com/*"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.worldquantbrain.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_start"
        }
    ]
}
